# Normalize line endings: store as LF in the repo, check out native per-OS.
* text=auto eol=lf

# Explicitly text
*.html  text
*.css   text
*.js    text
*.json  text
*.md    text
*.svg   text

# Binary assets (never normalize)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
